# ============================================================
# SAGA - 环境变量配置模板
# 复制为 .env 后按需修改
# cp .env.example .env
# ============================================================

# === 服务器端口配置 ===
SAGA_WS_HOST=0.0.0.0
SAGA_WS_PORT=8765
SAGA_HTTP_HOST=0.0.0.0
SAGA_HTTP_PORT=8080

# === LLM 后端配置 ===
SAGA_LLM_BACKEND=mock
SAGA_OLLAMA_BASE_URL=http://localhost:11434
SAGA_OLLAMA_MODEL=qwen2.5:3b
SAGA_OPENAI_BASE_URL=http://localhost:8000/v1
SAGA_OPENAI_API_KEY=EMPTY
SAGA_OPENAI_MODEL=qwen2.5:3b
SAGA_LLM_TEMPERATURE=0.7
SAGA_LLM_MAX_RETRIES=3
SAGA_LLM_TIMEOUT_SECONDS=30
SAGA_AGENT_CONCURRENCY=50
SAGA_AGENT_BATCH_SIZE=10

# === 图生成默认参数 ===
SAGA_DEFAULT_NUM_NODES=1000
SAGA_DEFAULT_NUM_EDGES=5000
SAGA_DEFAULT_GAMMA=2.5
SAGA_DEFAULT_HUB_RATIO=0.05

# === 时间维度默认参数 ===
SAGA_DEFAULT_TIME_SPAN_VALUE=30
SAGA_DEFAULT_TIME_SPAN_UNIT=day
SAGA_DEFAULT_MACRO_BLOCK_UNIT=day
SAGA_DEFAULT_MICRO_GRANULARITY=minute

# === 输出配置 ===
SAGA_OUTPUT_DIR=./output
SAGA_DEFAULT_OUTPUT_FORMATS=json,csv
SAGA_LOG_LEVEL=INFO
SAGA_LOG_FILE=./output/saga.log

# === 预估基准值 ===
SAGA_MOCK_SPEED_EDGES_PER_SEC=5000
SAGA_LLM_SPEED_EDGES_PER_SEC=100
SAGA_AVG_EDGE_BYTES_JSON=200
SAGA_AVG_EDGE_BYTES_CSV=80
SAGA_AVG_EDGE_BYTES_GRAPHML=300

# === 前端 ===
VITE_WS_URL=ws://localhost:8765
VITE_HTTP_URL=http://localhost:8080
